# Telegram (notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Anthropic (post classification)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Nextdoor accounts (format: NEXTDOOR_ACCOUNT_N_CityName=email:password)
NEXTDOOR_ACCOUNT_1_Norwalk=email@example.com:yourpassword
NEXTDOOR_ACCOUNT_2_Bridgeport=email@example.com:yourpassword

# Gmail (Facebook email notifications → leads)
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Facebook & Nextdoor session paths
FACEBOOK_SESSION_PATH=./sessions/facebook
NEXTDOOR_SESSION_PATH=./sessions/nextdoor

# Nextdoor specific neighborhoods to watch (comma-separated full URLs)
NEXTDOOR_NEIGHBORHOOD_URLS=

# Monitoring config
SCORE_THRESHOLD=7        # Min score (1-10) to trigger alert
DAILY_SMS_LIMIT=50       # Max SMS alerts per day before pausing
MAX_POST_AGE_MINUTES=120 # Ignore posts older than this
